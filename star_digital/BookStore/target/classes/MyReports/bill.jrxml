<jasperReport name="bill" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="412f2dc8-4298-4a77-bc7d-ec69ac676a65">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="orderId" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    o.order_id            AS orderId,
    i.item_name           AS itemName,
    oi.unit_price         AS unitPrice,
    oi.quantity           AS quantity,
    oi.line_total         AS lineTotal,
    
    o.customer_id         AS customerId,
    o.order_contact       AS orderContact,
    o.order_type          AS orderType,
    o.order_date          AS orderDate,
    o.amount              AS amount,
    o.discount            AS discount,
    o.total               AS totalAmount,
    
    p.payment_method      AS paymentMethod,
    p.paid_amount         AS paidAmount,
    p.balance             AS balance

FROM orders o
INNER JOIN order_items oi
    ON o.order_id = oi.order_id
INNER JOIN item i
    ON oi.item_id = i.item_id
LEFT JOIN payment p
    ON o.order_id = p.order_id

WHERE o.order_id = $P{orderId}
]]></query>
	<field name="orderId" class="java.lang.String"/>
	<field name="itemName" class="java.lang.String"/>
	<field name="unitPrice" class="java.math.BigDecimal"/>

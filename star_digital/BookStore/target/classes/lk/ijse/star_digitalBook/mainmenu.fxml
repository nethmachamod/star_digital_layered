<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="1100.0" stylesheets="@../../../css/mainmenu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.star_digitalBook.controller.MainmenuController">
    <children>
        <AnchorPane>
            <children>
                <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                    <!-- ================= LEFT SIDE ================= -->
                    <left>
                        <AnchorPane prefHeight="578.0" prefWidth="349.0" styleClass="left-panel" BorderPane.alignment="CENTER">
                            <children>

                                      <!-- Menu Management Button -->
                                <Button layoutX="22.0" layoutY="75.0" onAction="#clickmenu" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Menu Management">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </Button>

                                <!-- Order Management Button -->
                                <Button layoutX="22.0" layoutY="130.0" onAction="#clickorder" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Order Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Inventory Management Button -->
                                <Button layoutX="21.0" layoutY="185.0" onAction="#clickstock" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Inventory Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Employee Management Button -->
                                <Button layoutX="20.0" layoutY="241.0" onAction="#clickemp" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Employee Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Item Management Button -->
                                <Button fx:id="itemmanage" layoutX="20.0" layoutY="296.0" onAction="#clicksitems" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Item Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Supplier Management Button -->
                                <Button layoutX="20.0" layoutY="352.0" onAction="#clicksup" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Supplier Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Sales Reports Button -->
                                <Button layoutX="21.0" layoutY="409.0" onAction="#clicksales" prefHeight="49.0" prefWidth="235" styleClass="menu-button" text="Sales Reports">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>

                                <!-- Logout Button -->
                                <Button fx:id="logoutBtn" layoutX="77.0" layoutY="546.0" onAction="#logout" prefHeight="40" prefWidth="108.0" styleClass="logout-button" text="LOG OUT ↩️" AnchorPane.bottomAnchor="14.0" />
                                <Button layoutX="21.0" layoutY="466.0" onAction="#clickpay" prefHeight="49" prefWidth="235" styleClass="menu-button" text="Payment Management">
                           <opaqueInsets>
                              <Insets bottom="5.0" top="5.0" />
                           </opaqueInsets>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding></Button>
                            </children>
                            <BorderPane.margin>
                                <Insets />
                            </BorderPane.margin>
                        </AnchorPane>
                    </left>

                    <!-- ================= RIGHT SIDE ================= -->
                    <right>
                        <AnchorPane fx:id="maincontent" prefHeight="600.0" prefWidth="838.0" styleClass="content-pane" BorderPane.alignment="CENTER" />
                    </right>
                </BorderPane>
            </children>
        </AnchorPane>
    </children>
</StackPane>

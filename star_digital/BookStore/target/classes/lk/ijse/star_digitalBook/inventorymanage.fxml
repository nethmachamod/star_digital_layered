<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="822.0" stylesheets="@../../../css/stockmanage.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.star_digitalBook.controller.InventorymanageController">
